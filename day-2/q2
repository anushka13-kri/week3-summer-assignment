class Solution {
    public ListNode removeNthFromEnd(ListNode head, int n) {
        ListNode temp=head;
        int len=0;
        while(temp!=null){
            temp=temp.next;
            len++;
        }
        if (n == len) 
            return head.next;
        temp=head;
        for(int i=1;i<len-n;i++){
            temp=temp.next;
        }
        temp.next=temp.next.next;
        return head;
    }
}
